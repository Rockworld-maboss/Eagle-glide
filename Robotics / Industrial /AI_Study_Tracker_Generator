function buildDashboardV2(sheet) {
  const headers = [
    "Category","Total_Skills","Current_Score_Sum","Max_Score",
    "Progress_Percent","Completed_Skills_At_3plus","High_Priority_Open","Notes"
  ];

  const categories = [
    "Core Software",
    "Networking",
    "ROS Fundamentals",
    "ROS Troubleshooting",
    "ROS Visualization and Simulation",
    "Industrial Fundamentals",
    "PLC and Control",
    "Industrial Networks",
    "Robot Software and Controller",
    "Industrial Diagnostics",
    "Backup and Config Control",
    "Automation Engineering",
    "AI and Data",
    "Troubleshooting Behavior"
  ];

  sheet.getRange(1,1,1,headers.length).setValues([headers]);
  const rows = categories.map(c => [c,"","","","","","",""]);
  sheet.getRange(2,1,rows.length,headers.length).setValues(rows);

  const lastRow = sheet.getLastRow();
  for (let r = 2; r <= lastRow; r++) {
    sheet.getRange(r,2).setFormula(`=COUNTIF(${TRACKER_CONFIG.sheets.skills}!A:A,A${r})`);
    sheet.getRange(r,3).setFormula(`=SUMIF(${TRACKER_CONFIG.sheets.skills}!A:A,A${r},${TRACKER_CONFIG.sheets.skills}!D:D)`);
    sheet.getRange(r,4).setFormula(`=B${r}*5`);
    sheet.getRange(r,5).setFormula(`=IF(D${r}=0,0,C${r}/D${r})`);
    sheet.getRange(r,6).setFormula(`=COUNTIFS(${TRACKER_CONFIG.sheets.skills}!A:A,A${r},${TRACKER_CONFIG.sheets.skills}!D:D,">=3")`);
    sheet.getRange(r,7).setFormula(`=COUNTIFS(${TRACKER_CONFIG.sheets.skills}!A:A,A${r},${TRACKER_CONFIG.sheets.skills}!F:F,"High",${TRACKER_CONFIG.sheets.skills}!D:D,"<3")`);
  }

  sheet.getRange("A20").setValue("Overall_Total_Skills");
  sheet.getRange("B20").setFormula(`=COUNTA(${TRACKER_CONFIG.sheets.skills}!B:B)-1`);
  sheet.getRange("A21").setValue("Overall_Current_Score");
  sheet.getRange("B21").setFormula(`=SUM(${TRACKER_CONFIG.sheets.skills}!D:D)`);
  sheet.getRange("A22").setValue("Overall_Max_Score");
  sheet.getRange("B22").setFormula(`=B20*5`);
  sheet.getRange("A23").setValue("Overall_Progress");
  sheet.getRange("B23").setFormula(`=IF(B22=0,0,B21/B22)`);
  sheet.getRange("A24").setValue("Total_Skills_At_3plus");
  sheet.getRange("B24").setFormula(`=COUNTIF(${TRACKER_CONFIG.sheets.skills}!D:D,">=3")`);
  sheet.getRange("A25").setValue("Completed_Weeks");
  sheet.getRange("B25").setFormula(`=COUNTIF(${TRACKER_CONFIG.sheets.tracker}!H:H,"Yes")`);

  styleSheetV2(sheet, headers.length);
  sheet.setFrozenRows(1);
  setColumnWidthsV2(sheet, [240,110,140,110,130,160,140,180]);
  sheet.getRange("E2:E15").setNumberFormat("0.00%");
  sheet.getRange("B23").setNumberFormat("0.00%");

  applyDashboardConditionalFormattingV2(sheet, lastRow);
  createDashboardChartsV2(sheet);
}

