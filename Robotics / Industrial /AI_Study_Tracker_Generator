function createRoboticsStudyTrackerV2() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const sheetNames = Object.values(TRACKER_CONFIG.sheets);

  sheetNames.forEach(name => {
    const sh = ss.getSheetByName(name);
    if (sh) ss.deleteSheet(sh);
  });

  const skillsSheet = ss.insertSheet(TRACKER_CONFIG.sheets.skills);
  const trackerSheet = ss.insertSheet(TRACKER_CONFIG.sheets.tracker);
  const dashboardSheet = ss.insertSheet(TRACKER_CONFIG.sheets.dashboard);
  const projectsSheet = ss.insertSheet(TRACKER_CONFIG.sheets.projects);
  const weeklyMapSheet = ss.insertSheet(TRACKER_CONFIG.sheets.weeklyMap);

  buildSkillsMatrixV2(skillsSheet);
  buildWeekTrackerV2(trackerSheet);
  buildDashboardV2(dashboardSheet);
  buildProjectsRegisterV2(projectsSheet);
  buildWeeklySkillMapV2(weeklyMapSheet);

  applyAllDataValidations();
  applyHeaderProtections();
  applyGlobalFormattingV2(ss);

  SpreadsheetApp.flush();
}

function buildSkillsMatrixV2(sheet) {
  const headers = [
    "Category","Skill","Target_Level","Current_Level","Status","Priority",
    "Week_Planned","Last_Practiced","Evidence","Project_Name","Notes","Overdue"
  ];

  const rows = getSkillsRows();

  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);

  const lastRow = sheet.getLastRow();

  for (let r = 2; r <= lastRow; r++) {
    sheet.getRange(r, TRACKER_CONFIG.columns.skills.status).setFormula(
      '=IF(D' + r + '="","",IF(D' + r + '=0,"Not started",IF(D' + r + '=1,"Read/Watched",IF(D' + r + '=2,"Practiced with help",IF(D' + r + '=3,"Independent simple case",IF(D' + r + '=4,"Can troubleshoot/explain","Real project capable"))))))'
    );

    sheet.getRange(r, TRACKER_CONFIG.columns.skills.overdue).setFormula(
      '=IF(AND(G' + r + '<>"",D' + r + '<3,G' + r + '<=IFERROR(MAX(FILTER(' +
      TRACKER_CONFIG.sheets.tracker + '!A:A,' + TRACKER_CONFIG.sheets.tracker + '!H:H="Yes")),0)),"Yes","")'
    );
  }

  styleSheetV2(sheet, headers.length);
  addFilterV2(sheet, headers.length);
  setColumnWidthsV2(sheet, [180,260,100,100,180,90,100,120,220,160,220,90]);
  sheet.setFrozenRows(1);

  applySkillsConditionalFormattingV2(sheet, lastRow);
}

