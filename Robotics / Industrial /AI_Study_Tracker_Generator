function applyAllDataValidations() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const skillsSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.skills);
  const trackerSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.tracker);
  const projectsSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.projects);

  if (skillsSheet) {
    const lastRow = skillsSheet.getLastRow();

    const currentLevelRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(["0","1","2","3","4","5"], true)
      .setAllowInvalid(false)
      .build();
    skillsSheet.getRange(2, TRACKER_CONFIG.columns.skills.current, lastRow - 1, 1).setDataValidation(currentLevelRule);

    const priorityRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(["High","Medium","Low"], true)
      .setAllowInvalid(false)
      .build();
    skillsSheet.getRange(2, TRACKER_CONFIG.columns.skills.priority, lastRow - 1, 1).setDataValidation(priorityRule);

    const weekRule = SpreadsheetApp.newDataValidation()
      .requireNumberBetween(1, 16)
      .setAllowInvalid(false)
      .build();
    skillsSheet.getRange(2, TRACKER_CONFIG.columns.skills.weekPlanned, lastRow - 1, 1).setDataValidation(weekRule);
  }

  if (trackerSheet) {
    const lastRow = trackerSheet.getLastRow();

    const doneRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(["No","Yes"], true)
      .setAllowInvalid(false)
      .build();
    trackerSheet.getRange(2, TRACKER_CONFIG.columns.tracker.done, lastRow - 1, 1).setDataValidation(doneRule);

    const actualLevelRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(["0","1","2","3","4","5"], true)
      .setAllowInvalid(false)
      .build();
    trackerSheet.getRange(2, TRACKER_CONFIG.columns.tracker.actualLevel, lastRow - 1, 1).setDataValidation(actualLevelRule);

    const completionRule = SpreadsheetApp.newDataValidation()
      .requireNumberBetween(0, 100)
      .setAllowInvalid(true)
      .build();
    trackerSheet.getRange(2, TRACKER_CONFIG.columns.tracker.completionPercent, lastRow - 1, 1).setDataValidation(completionRule);
  }

  if (projectsSheet) {
    const lastRow = projectsSheet.getLastRow();

    const statusRule = SpreadsheetApp.newDataValidation()
      .requireValueInList(["Planned","In Progress","Done"], true)
      .setAllowInvalid(false)
      .build();
    projectsSheet.getRange(2, TRACKER_CONFIG.columns.projects.status, lastRow - 1, 1).setDataValidation(statusRule);
  }
}

function applyHeaderProtections() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  Object.values(TRACKER_CONFIG.sheets).forEach(name => {
    const sheet = ss.getSheetByName(name);
    if (!sheet) return;

    removeExistingHeaderProtections(sheet);

    const range = sheet.getRange(1, 1, 1, sheet.getLastColumn());
    const protection = range.protect().setDescription(`Protected header row - ${name}`);

    try {
      const me = Session.getEffectiveUser();
      protection.addEditor(me);
      protection.removeEditors(protection.getEditors().filter(e => e.getEmail() !== me.getEmail()));
      if (protection.canDomainEdit()) protection.setDomainEdit(false);
    } catch (e) {
      // ignore editor-setting issues
    }
  });
}

function removeExistingHeaderProtections(sheet) {
  const protections = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);
  protections.forEach(p => {
    const r = p.getRange();
    if (r.getRow() === 1 && r.getNumRows() === 1) {
      try {
        p.remove();
      } catch (e) {}
    }
  });
}

function onEdit(e) {
  try {
    if (!e || !e.range) return;

    const sheet = e.range.getSheet();
    const sheetName = sheet.getName();

    if (sheetName === TRACKER_CONFIG.sheets.skills) {
      handleSkillsMatrixEdit_(e);
    } else if (sheetName === TRACKER_CONFIG.sheets.tracker) {
      handleWeekTrackerEdit_(e);
    } else if (sheetName === TRACKER_CONFIG.sheets.projects) {
      handleProjectsEdit_(e);
    }
  } catch (err) {
    Logger.log("onEdit error: " + err);
  }
}

function handleSkillsMatrixEdit_(e) {
  const sheet = e.range.getSheet();
  const row = e.range.getRow();
  const col = e.range.getColumn();

  if (row === 1) return;

  const c = TRACKER_CONFIG.columns.skills;

  // Automatic timestamp when Current_Level is updated
  if (col === c.current) {
    const value = e.range.getValue();
    if (value !== "" && value !== null) {
      sheet.getRange(row, c.lastPracticed).setValue(new Date());
    } else {
      sheet.getRange(row, c.lastPracticed).clearContent();
    }
  }

  // Optional: if Evidence updated and Last_Practiced empty, set timestamp
  if (col === c.evidence) {
    const lastPracticedCell = sheet.getRange(row, c.lastPracticed);
    if (!lastPracticedCell.getValue()) {
      lastPracticedCell.setValue(new Date());
    }
  }
}

function handleWeekTrackerEdit_(e) {
  const sheet = e.range.getSheet();
  const row = e.range.getRow();
  const col = e.range.getColumn();

  if (row === 1) return;

  const c = TRACKER_CONFIG.columns.tracker;

  // If Done = Yes and Completion is empty or formula-based, set to 100
  if (col === c.done) {
    const doneValue = sheet.getRange(row, c.done).getValue();
    if (doneValue === "Yes") {
      sheet.getRange(row, c.completionPercent).setValue(100);
    } else if (doneValue === "No") {
      sheet.getRange(row, c.completionPercent).setValue(0);
    }
  }
}

function handleProjectsEdit_(e) {
  const sheet = e.range.getSheet();
  const row = e.range.getRow();
  const col = e.range.getColumn();

  if (row === 1) return;

  const c = TRACKER_CONFIG.columns.projects;

  // If project status changes, update completion %
  if (col === c.status) {
    const status = sheet.getRange(row, c.status).getValue();
    if (status === "Done") {
      sheet.getRange(row, c.completion).setValue(100);
    } else if (status === "In Progress") {
      sheet.getRange(row, c.completion).setValue(50);
    } else {
      sheet.getRange(row, c.completion).setValue(0);
    }
  }
}

function styleSheetV2(sheet, numCols) {
  sheet.getRange(1,1,1,numCols)
    .setBackground("#1f4e78")
    .setFontColor("#ffffff")
    .setFontWeight("bold")
    .setHorizontalAlignment("center");

  sheet.getDataRange().setVerticalAlignment("middle");
  sheet.getDataRange().setWrap(true);
}

function addFilterV2(sheet, numCols) {
  const range = sheet.getRange(1,1,sheet.getLastRow(),numCols);
  if (sheet.getFilter()) sheet.getFilter().remove();
  range.createFilter();
}

function setColumnWidthsV2(sheet, widths) {
  widths.forEach((w, i) => sheet.setColumnWidth(i + 1, w));
}

function applySkillsConditionalFormattingV2(sheet, lastRow) {
  const rules = [];

  const levelRange = sheet.getRange(`D2:D${lastRow}`);
  rules.push(
    SpreadsheetApp.newConditionalFormatRule().whenNumberEqualTo(0).setBackground("#f4cccc").setRanges([levelRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberEqualTo(1).setBackground("#fce5cd").setRanges([levelRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberEqualTo(2).setBackground("#fff2cc").setRanges([levelRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberEqualTo(3).setBackground("#d9ead3").setRanges([levelRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberEqualTo(4).setBackground("#93c47d").setRanges([levelRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberEqualTo(5).setBackground("#6aa84f").setFontColor("#ffffff").setRanges([levelRange]).build()
  );

  const priorityRange = sheet.getRange(`F2:F${lastRow}`);
  rules.push(
    SpreadsheetApp.newConditionalFormatRule().whenTextEqualTo("High").setBackground("#f4cccc").setBold(true).setRanges([priorityRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenTextEqualTo("Medium").setBackground("#fce5cd").setRanges([priorityRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenTextEqualTo("Low").setBackground("#eeeeee").setRanges([priorityRange]).build()
  );

  const overdueRange = sheet.getRange(`L2:L${lastRow}`);
  rules.push(
    SpreadsheetApp.newConditionalFormatRule().whenTextEqualTo("Yes").setBackground("#ea9999").setBold(true).setRanges([overdueRange]).build()
  );

  const dateRange = sheet.getRange(`H2:H${lastRow}`);
  rules.push(
    SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied('=AND(H2<>"",TODAY()-H2>21)').setBackground("#fff2cc").setRanges([dateRange]).build()
  );

  sheet.setConditionalFormatRules(rules);
}

function applyTrackerConditionalFormattingV2(sheet, lastRow) {
  const rules = [];

  const doneRange = sheet.getRange(`H2:H${lastRow}`);
  const compRange = sheet.getRange(`I2:I${lastRow}`);

  rules.push(
    SpreadsheetApp.newConditionalFormatRule().whenTextEqualTo("No").setBackground("#f4cccc").setRanges([doneRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenTextEqualTo("Yes").setBackground("#d9ead3").setRanges([doneRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberLessThan(50).setBackground("#f4cccc").setRanges([compRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberBetween(50,79).setBackground("#fff2cc").setRanges([compRange]).build(),
    SpreadsheetApp.newConditionalFormatRule().whenNumberGreaterThanOrEqualTo(80).setBackground("#d9ead3").setRanges([compRange]).build()
  );

  sheet.setConditionalFormatRules(rules);
}

function applyDashboardConditionalFormattingV2(sheet, lastRow) {
  const rules = [];
  const progressRange = sheet.getRange(`E2:E${lastRow}`);

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=E2<0.4')
      .setBackground("#f4cccc")
      .setRanges([progressRange]).build(),
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=AND(E2>=0.4,E2<0.7)')
      .setBackground("#fff2cc")
      .setRanges([progressRange]).build(),
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=E2>=0.7')
      .setBackground("#d9ead3")
      .setRanges([progressRange]).build()
  );

  sheet.setConditionalFormatRules(rules);
}

function createDashboardChartsV2(sheet) {
  removeExistingCharts(sheet);

  const progressChart = sheet.newChart()
    .setChartType(Charts.ChartType.BAR)
    .addRange(sheet.getRange("A1:A15"))
    .addRange(sheet.getRange("E1:E15"))
    .setPosition(2, 10, 0, 0)
    .setOption("title", "Progress by Category")
    .setOption("legend", { position: "none" })
    .setOption("hAxis", { format: "percent" })
    .build();
  sheet.insertChart(progressChart);

  const completedChart = sheet.newChart()
    .setChartType(Charts.ChartType.COLUMN)
    .addRange(sheet.getRange("A1:A15"))
    .addRange(sheet.getRange("F1:F15"))
    .setPosition(20, 10, 0, 0)
    .setOption("title", "Completed Skills at Level 3+")
    .setOption("legend", { position: "none" })
    .build();
  sheet.insertChart(completedChart);

  const highPriorityChart = sheet.newChart()
    .setChartType(Charts.ChartType.BAR)
    .addRange(sheet.getRange("A1:A15"))
    .addRange(sheet.getRange("G1:G15"))
    .setPosition(38, 10, 0, 0)
    .setOption("title", "High Priority Open Skills")
    .setOption("legend", { position: "none" })
    .build();
  sheet.insertChart(highPriorityChart);
}

function removeExistingCharts(sheet) {
  const charts = sheet.getCharts();
  charts.forEach(chart => sheet.removeChart(chart));
}

function applyGlobalFormattingV2(ss) {
  ss.getSheets().forEach(sheet => {
    sheet.getDataRange().setFontFamily("Arial").setFontSize(10);
  });

  const skillsSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.skills);
  const trackerSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.tracker);
  const dashboardSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.dashboard);
  const projectsSheet = ss.getSheetByName(TRACKER_CONFIG.sheets.projects);

  if (skillsSheet) {
    const lastRow = skillsSheet.getLastRow();
    if (lastRow > 1) {
      skillsSheet.getRange(2, TRACKER_CONFIG.columns.skills.lastPracticed, lastRow - 1, 1)
        .setNumberFormat("yyyy-mm-dd hh:mm");
    }
  }

  if (dashboardSheet) {
    dashboardSheet.getRange("E2:E15").setNumberFormat("0.00%");
    dashboardSheet.getRange("B23").setNumberFormat("0.00%");
  }

  if (trackerSheet) {
    const lastRow = trackerSheet.getLastRow();
    if (lastRow > 1) {
      trackerSheet.getRange(2, TRACKER_CONFIG.columns.tracker.completionPercent, lastRow - 1, 1)
        .setNumberFormat("0");
    }
  }

  if (projectsSheet) {
    const lastRow = projectsSheet.getLastRow();
    if (lastRow > 1) {
      projectsSheet.getRange(2, TRACKER_CONFIG.columns.projects.completion, lastRow - 1, 1)
        .setNumberFormat("0");
    }
  }
}

