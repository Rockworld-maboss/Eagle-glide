function buildWeeklySkillMapV2(sheet) {
  const headers = ["Week","Skill"];
  sheet.getRange(1,1,1,headers.length).setValues([headers]);

  const skillsSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(TRACKER_CONFIG.sheets.skills);
  const data = skillsSheet.getRange(2,1,skillsSheet.getLastRow()-1,7).getValues();
  const rows = [];

  data.forEach(r => {
    const week = r[6];
    const skill = r[1];
    if (week && skill) rows.push([week, skill]);
  });

  if (rows.length > 0) {
    sheet.getRange(2,1,rows.length,2).setValues(rows);
  }

  styleSheetV2(sheet, headers.length);
  addFilterV2(sheet, headers.length);
  sheet.setFrozenRows(1);
  setColumnWidthsV2(sheet, [80,320]);
}

